{
  "name": "@cntryl/fitz",
  "version": "0.1.0",
  "description": "TypeScript client library for Fitz distributed system",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "pack:smoke": "npm pack --pack-destination ./artifacts",
    "test": "npm run test:unit && npm run test:integration",
    "test:spec": "npm run test:conformance",
    "verify": "npm run typecheck && npm run lint && npm run fmt:check && npm run build && npm run test:unit && npm run test:integration && npm run test:conformance",
    "typecheck": "tsc -p tsconfig.json",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:conformance": "vitest run --config vitest.conformance.config.ts --reporter=verbose",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "bench": "vitest bench",
    "lint": "oxlint src tests --deny-warnings",
    "lint:fix": "oxlint src tests --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cntryl/fitz-ts.git"
  },
  "homepage": "https://github.com/cntryl/fitz-ts#readme",
  "bugs": {
    "url": "https://github.com/cntryl/fitz-ts/issues"
  },
  "keywords": [
    "fitz",
    "distributed-systems",
    "websocket",
    "tcp",
    "rpc",
    "queue",
    "stream"
  ],
  "publishConfig": {
    "access": "public"
  }
}
